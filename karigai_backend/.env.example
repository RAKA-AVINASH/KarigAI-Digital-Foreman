# KarigAI Backend Configuration

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/karigai
REDIS_URL=redis://localhost:6379/0

# AI Service Mode Configuration
# Options: paid_apis, colab_models, hybrid, offline_only
AI_SERVICE_MODE=paid_apis

# Paid API Keys (for paid_apis and hybrid modes)
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_CLOUD_API_KEY=your_google_cloud_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Google Colab Model Endpoints (for colab_models and hybrid modes)
# These URLs will be generated when you deploy models in Google Colab with ngrok
COLAB_VOICE_ENDPOINT=https://your-ngrok-url.ngrok.io/voice
COLAB_VISION_ENDPOINT=https://your-ngrok-url.ngrok.io/vision
COLAB_NLP_ENDPOINT=https://your-ngrok-url.ngrok.io/nlp

# Cost Management
MAX_DAILY_API_COST=10.0
COST_TRACKING_ENABLED=true

# Performance Settings
AI_REQUEST_TIMEOUT=30
MAX_CONCURRENT_AI_REQUESTS=10
CACHE_AI_RESULTS=true
CACHE_TTL_SECONDS=3600

# Fallback Configuration
ENABLE_AI_FALLBACK=true

# WhatsApp Integration
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Security
SECRET_KEY=your_secret_key_here
JWT_SECRET_KEY=your_jwt_secret_key_here

# File Storage
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=16777216  # 16MB

# Logging
LOG_LEVEL=INFO
SENTRY_DSN=your_sentry_dsn_here

# Development Settings
DEBUG=false
TESTING=false

# Example configurations for different deployment scenarios:

# Scenario 1: Full Paid APIs (Recommended for production with budget)
# AI_SERVICE_MODE=paid_apis
# OPENAI_API_KEY=sk-...
# GOOGLE_CLOUD_API_KEY=...
# ELEVENLABS_API_KEY=...

# Scenario 2: Google Colab Models Only (Zero cost option)
# AI_SERVICE_MODE=colab_models
# COLAB_VOICE_ENDPOINT=https://abc123.ngrok.io/voice
# COLAB_VISION_ENDPOINT=https://abc123.ngrok.io/vision
# COLAB_NLP_ENDPOINT=https://abc123.ngrok.io/nlp

# Scenario 3: Hybrid (Paid APIs with Colab fallback)
# AI_SERVICE_MODE=hybrid
# OPENAI_API_KEY=sk-...
# COLAB_VOICE_ENDPOINT=https://abc123.ngrok.io/voice
# MAX_DAILY_API_COST=5.0

# Scenario 4: Offline Only (For areas with no internet)
# AI_SERVICE_MODE=offline_only
# CACHE_AI_RESULTS=true