{
  "quantization": {
    "int8_enabled": true,
    "fp16_enabled": true,
    "dynamic_quantization": true,
    "static_quantization": false,
    "calibration_samples": 100,
    "quantization_backends": ["fbgemm", "qnnpack"]
  },
  "pruning": {
    "structured_pruning": true,
    "unstructured_pruning": true,
    "sparsity_levels": [0.1, 0.3, 0.5, 0.7, 0.9],
    "pruning_methods": ["magnitude", "random", "structured"],
    "gradual_pruning": true,
    "fine_tuning_epochs": 5
  },
  "distillation": {
    "temperature": 4.0,
    "alpha": 0.7,
    "beta": 0.3,
    "student_architectures": [
      "mobilenet_v2",
      "efficientnet_b0",
      "resnet18",
      "squeezenet1_1"
    ],
    "distillation_loss": "kl_divergence",
    "training_epochs": 50
  },
  "batch_optimization": {
    "test_batch_sizes": [1, 2, 4, 8, 16, 32, 64, 128],
    "max_batch_size": 256,
    "memory_limit_gb": 8,
    "optimize_for": "throughput"
  },
  "profiling": {
    "profile_iterations": 100,
    "warmup_iterations": 10,
    "detailed_profiling": true,
    "profile_memory": true,
    "profile_cpu": true,
    "profile_gpu": true
  },
  "optimization_targets": {
    "primary_metric": "latency",
    "secondary_metric": "model_size",
    "accuracy_threshold": 0.02,
    "max_latency_ms": 200,
    "max_model_size_mb": 100
  },
  "hardware_profiles": {
    "mobile": {
      "max_model_size_mb": 50,
      "max_latency_ms": 100,
      "memory_limit_mb": 512,
      "prefer_quantization": true
    },
    "edge": {
      "max_model_size_mb": 200,
      "max_latency_ms": 50,
      "memory_limit_mb": 2048,
      "prefer_pruning": true
    },
    "server": {
      "max_model_size_mb": 1000,
      "max_latency_ms": 20,
      "memory_limit_mb": 8192,
      "prefer_batch_optimization": true
    }
  },
  "export_formats": {
    "onnx": {
      "enabled": true,
      "opset_version": 11,
      "optimize": true,
      "quantize": true
    },
    "torchscript": {
      "enabled": true,
      "optimize_for_inference": true,
      "strict": false
    },
    "tensorrt": {
      "enabled": false,
      "precision": "fp16",
      "max_workspace_size": 1073741824
    },
    "coreml": {
      "enabled": false,
      "compute_units": "all"
    }
  },
  "validation": {
    "accuracy_validation": true,
    "performance_validation": true,
    "memory_validation": true,
    "numerical_stability": true,
    "cross_platform_validation": false
  },
  "logging": {
    "level": "INFO",
    "save_logs": true,
    "log_file": "optimization.log",
    "verbose_profiling": false
  }
}